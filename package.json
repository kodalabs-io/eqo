{
  "name": "@kodalabs-io/eqo",
  "version": "1.0.0",
  "description": "RGAA v4.1.2 accessibility compliance analyzer for NextJS projects",
  "type": "module",
  "bin": {
    "eqo": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "!dist/cli/worker.js",
    "!dist/action.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "action.yml"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "rm -f dist/cli/worker.js dist/cli/worker.js.map",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "size": "size-limit"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "commander": "^14.0.3",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.3",
    "piscina": "^5.1.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@axe-core/playwright": ">=4.11.1",
    "axe-core": ">=4.11.1",
    "playwright": ">=1.58.2"
  },
  "peerDependenciesMeta": {
    "@axe-core/playwright": {
      "optional": true
    },
    "axe-core": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/types": "^7.24.0",
    "@biomejs/biome": "^2.4.4",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@size-limit/file": "^12.0.0",
    "@types/node": "^22.15.0",
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^1.5.0",
    "size-limit": "^12.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "rgaa",
    "wcag",
    "apca",
    "nextjs",
    "audit",
    "compliance",
    "french",
    "ci-cd"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kodalabs-io/eqo.git"
  },
  "homepage": "https://github.com/kodalabs-io/eqo#readme",
  "bugs": {
    "url": "https://github.com/kodalabs-io/eqo/issues"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.0.0"
}
